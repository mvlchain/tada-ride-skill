---
const steps = [
  { num: '1', title: 'Install', desc: 'Add skill to Claude Code or OpenClaw' },
  { num: '2', title: 'Setup Wallet', desc: 'Auto-create or connect external wallet' },
  { num: '3', title: 'Ride!', desc: '"Book a ride to Times Square"' },
];
---
<section class="section">
  <div class="container">
    <p class="section-label">How It Works</p>
    <h2 class="section-title">Three steps to your first ride</h2>
    <div class="steps">
      {steps.map(s => (
        <div class="step">
          <div class="step-num">{s.num}</div>
          <h3 class="step-title">{s.title}</h3>
          <p class="step-desc">{s.desc}</p>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .steps {
    display: flex;
    gap: 24px;
    justify-content: center;
    max-width: 700px;
    margin: 0 auto;
  }
  .step {
    flex: 1;
    text-align: center;
    padding: 24px;
  }
  .step-num {
    width: 44px;
    height: 44px;
    border-radius: 50%;
    border: 2px solid var(--color-accent);
    display: flex;
    align-items: center;
    justify-content: center;
    margin: 0 auto 16px;
    color: var(--color-accent);
    font-weight: 600;
    font-size: 16px;
    font-family: var(--font-heading);
  }
  .step-title {
    font-size: 16px;
    font-weight: 600;
    margin-bottom: 8px;
  }
  .step-desc {
    font-size: 14px;
    color: var(--color-text-tertiary);
    line-height: 1.5;
  }

  @media (max-width: 768px) {
    .steps { flex-direction: column; align-items: center; }
    .step { max-width: 280px; }
  }
</style>
