---
---
<section id="installation" class="section">
  <div class="container">
    <p class="section-label">Installation</p>
    <h2 class="section-title">Get started in minutes</h2>
    <div class="install-grid">
      <div class="install-card install-card--active">
        <h3 class="install-card-title">Claude Code</h3>
        <pre class="install-code"><code><span class="prompt">$</span> git clone https://github.com/mvlchain/tada-ride-skill
<span class="prompt">$</span> cd tada-ride-skill
<span class="prompt">$</span> npm install --production
<span class="prompt">$</span> node scripts/install.js</code></pre>
      </div>
      <div class="install-card">
        <h3 class="install-card-title">OpenClaw</h3>
        <pre class="install-code"><code><span class="prompt">$</span> git clone https://github.com/mvlchain/tada-ride-skill
<span class="prompt">$</span> cd tada-ride-skill
<span class="prompt">$</span> npm install --production
<span class="prompt">$</span> node scripts/install.js</code></pre>
      </div>
    </div>
  </div>
</section>

<style>
  .install-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 24px;
    max-width: 800px;
    margin: 0 auto;
  }
  .install-card {
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    padding: 24px;
  }
  .install-card--active {
    border: 2px solid var(--color-accent);
  }
  .install-card-title {
    font-size: 15px;
    font-weight: 600;
    margin-bottom: 16px;
  }
  .install-card--active .install-card-title {
    color: var(--color-accent);
  }
  .install-code {
    background: var(--color-bg);
    border-radius: var(--radius-sm);
    padding: 16px;
    font-size: 13px;
    line-height: 1.7;
    overflow-x: auto;
    color: var(--color-text-secondary);
  }
  .prompt {
    color: var(--color-text-tertiary);
  }

  @media (max-width: 768px) {
    .install-grid { grid-template-columns: 1fr; }
  }
</style>
